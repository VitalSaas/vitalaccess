{
    "name": "vitalsaas/vitalaccess",
    "description": "Advanced Role-Based Access Control (RBAC) package with Filament integration - PLUG & PLAY setup in one command",
    "type": "library",
    "keywords": ["laravel", "rbac", "permissions", "roles", "filament", "vitalsaas", "plug-and-play", "admin-panel"],
    "homepage": "https://github.com/VitalSaaS/vitalaccess",
    "license": "MIT",
    "authors": [
        {
            "name": "VitalSaaS Team",
            "email": "info@vitalsaas.com",
            "homepage": "https://vitalsaas.com"
        }
    ],
    "support": {
        "issues": "https://github.com/VitalSaaS/vitalaccess/issues",
        "source": "https://github.com/VitalSaaS/vitalaccess",
        "docs": "https://github.com/VitalSaaS/vitalaccess#readme"
    },
    "require": {
        "php": "^8.3",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "filament/filament": "^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "VitalSaaS\\VitalAccess\\": "src/",
            "VitalSaaS\\VitalAccess\\Database\\Seeders\\": "database/seeders/",
            "VitalSaaS\\VitalAccess\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VitalSaaS\\VitalAccess\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage"
    },
    "extra": {
        "laravel": {
            "providers": [
                "VitalSaaS\\VitalAccess\\VitalAccessServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}